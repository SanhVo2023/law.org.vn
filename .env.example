# Database — law.org.vn on Authority project (Seoul)
# Supabase Ref: vvzpvkjlkmjjnhapsrxq
# Table Prefix: lov_   (CRITICAL — shared project with vothienhien.com [no prefix], lawyer.id.vn [lid_], law.pro.vn [lpv_])
# See: ../../shared-assets/SUPABASE_CONFIG.md for full details
# Session Pooler URI (IPv4, port 5432) — supports prepared statements AND `npx payload migrate`.
# DO NOT swap to a separate direct URI for migrations; the session pooler handles both.
DATABASE_URI=postgresql://postgres.vvzpvkjlkmjjnhapsrxq:[PASSWORD]@aws-1-ap-northeast-2.pooler.supabase.com:5432/postgres

# PayloadCMS secret — generate a random 32+ character string
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=your-secret-here

# Public site URL — change to https://law.org.vn when deploying
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase client keys (for client-side SDK if needed)
NEXT_PUBLIC_SUPABASE_URL=https://vvzpvkjlkmjjnhapsrxq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-dashboard
